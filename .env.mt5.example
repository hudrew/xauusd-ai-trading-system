# Copy this file to `.env.mt5.local` and fill in real values.
# The helper scripts under `scripts/` will load it automatically.

XAUUSD_AI_ENV=paper
XAUUSD_AI_LOG_LEVEL=INFO
XAUUSD_AI_DRY_RUN=true
XAUUSD_AI_POLL_INTERVAL_SECONDS=5
XAUUSD_AI_STARTING_EQUITY=10000

XAUUSD_AI_MARKET_DATA_PLATFORM=mt5
XAUUSD_AI_EXECUTION_PLATFORM=mt5

XAUUSD_AI_MT5_LOGIN=
XAUUSD_AI_MT5_PASSWORD=
# Example broker server observed during local MT5 manual debug.
XAUUSD_AI_MT5_SERVER=TradeMaxGlobal-Live
XAUUSD_AI_MT5_PATH=
XAUUSD_AI_MT5_SYMBOL=XAUUSD
XAUUSD_AI_MT5_TIMEFRAME=M1
XAUUSD_AI_MT5_HISTORY_BARS=500

# Optional MT5 execution tuning.
# XAUUSD_AI_MT5_DEVIATION=30
# XAUUSD_AI_MT5_MAGIC=2026032901

# Optional spread-based tuning.
# These are relative spread-ratio thresholds, not absolute spread values.
# XAUUSD_AI_RISK_CONTRACT_SIZE=100
# XAUUSD_AI_RISK_MAX_SPREAD_RATIO=1.40
# XAUUSD_AI_STATE_SPREAD_RATIO_MAX=1.50
# XAUUSD_AI_VOLATILITY_SPREAD_RATIO_TRIGGER=1.20

# Optional routing controls for research or staged rollout.
# Comma-separated, for example:
# XAUUSD_AI_DISABLED_STRATEGIES=breakout
# XAUUSD_AI_ALLOWED_SESSIONS=eu,overlap,us
# XAUUSD_AI_BLOCKED_SESSIONS=asia
# XAUUSD_AI_ENABLED_STRATEGIES=pullback,mean_reversion
#
# Optional: pin helper scripts to a non-default MT5 runtime config.
# Useful when running a branch paper candidate in parallel with the mainline paper track.
# XAUUSD_AI_CONFIG_PATH=configs/mt5_paper_pullback_sell_v3.yaml

XAUUSD_AI_DATABASE_URL=sqlite:///var/xauusd_ai/paper.db
XAUUSD_AI_WEBHOOK_URL=
